# Plataforma de reservas — variables de entorno.
# NO commitear valores reales. En Vercel se configuran por entorno.
# .env*.local está en .gitignore.

# Supabase (servidor)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (auth admin, públicas)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Allowlist de administradores (emails separados por coma)
ADMIN_EMAILS=

# Dev local (tras `npm run db:start`, puertos 544xx):
#   SUPABASE_URL=http://127.0.0.1:54421
#   SUPABASE_SERVICE_ROLE_KEY=  → output de `npm run db:start` (o `npx supabase status`)

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Secreto de firma del webhook (Webhooks → Clave secreta de la MISMA app que el
# access token). La firma es best-effort; la verdad del pago es la API de MP.
MP_WEBHOOK_SECRET=

# Sitio / feature flags
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Flujo de reserva: off por defecto en prod; se prende al lanzar el Corte 1.
NEXT_PUBLIC_BOOKING_ENABLED=false

# Emails (Resend) + cron
RESEND_API_KEY=
EMAIL_FROM=FOTF Studios <reservas@fotfstudios.cl>
OWNER_EMAIL=
CRON_SECRET=
