# Plataforma de reservas — variables de entorno.
# NO commitear valores reales. En Vercel se configuran por entorno.
# .env*.local está en .gitignore.

# Supabase (servidor)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (auth admin, públicas)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Allowlist de administradores (emails separados por coma)
ADMIN_EMAILS=

# Dev local (tras `npm run db:start`, puertos 544xx):
#   SUPABASE_URL=http://127.0.0.1:54421
#   SUPABASE_SERVICE_ROLE_KEY=  → output de `npm run db:start` (o `npx supabase status`)

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# MP_WEBHOOK_SECRET=   (PR7: secreto del webhook; se configura al desplegar)

# Sitio / feature flags
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Flujo de reserva: off por defecto en prod; se prende al lanzar el Corte 1.
NEXT_PUBLIC_BOOKING_ENABLED=false

# Próximos PRs:
# RESEND_API_KEY=
# CRON_SECRET=
